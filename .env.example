# ========================
# DevAgent 配置文件示例
# ========================
# 
# 使用方法:
# 1. 复制本文件为 .env
# 2. 填入你的 API 密钥
# 3. 启动项目
#
# 注意: .env 文件包含敏感信息，已被 .gitignore 忽略，不会上传到 GitHub

# ========================
# 【必需】LLM 配置 - DeepSeek
# ========================
# 获取方式: https://platform.deepseek.com
deepseek_api_key=sk-your-deepseek-api-key-here
deepseek_base_url=https://api.deepseek.com
model_name=deepseek-chat

# ========================
# 【推荐】嵌入向量模型配置 - Qwen
# ========================
# 获取方式: https://dashscope.aliyuncs.com
# 用途: 将用户查询和代码转换成高维向量进行语义搜索
qwen_api_key=sk-your-qwen-api-key-here
qwen_base_url=https://dashscope.aliyuncs.com/compatible-mode/v1
qwen_embedding_name=text-embedding-v4

# ========================
# 【可选】嵌入模型选择
# ========================
# 选项: "qwen" (推荐，需要 API 密钥) 或 "local" (离线，需要 4GB 磁盘空间)
embedding_provider=qwen

# 如果选择本地模型，默认使用:
local_embedding_name=all-MiniLM-L6-v2

# ========================
# 【可选】重排模型选择
# ========================
# 用于对搜索结果进行精排，提高准确度
# 选项: "qwen" 或 "local"
reranking_provider=qwen

# ========================
# 【可选】RAG 参数调优
# ========================
# 文本切分大小（字符数）
# 较小的 chunk_size 会增加细度但降低上下文完整性
chunk_size=200

# 块之间的重叠字符数
# 避免在块边界处丢失关键信息
chunk_overlap=200

# 搜索结果数量
# 返回给 LLM 的最相关代码片段数
top_k=5

# ========================
# 【可选】特性开关
# ========================
# 是否启用 Query Rewriter（将口语化查询改写为检索最优形式）
# 注意: 启用会增加 API 调用次数和延迟
enable_query_rewrite_in_tool=False

# ========================
# 【可选】数据存储路径
# ========================
# Chroma 向量数据库存储目录
Chroma_persist_dir=./data/Chroma

# BM25 索引文件路径
bm25_persist_dir=./data/bm25_index.pkl

# ========================
# 注意事项
# ========================
# 1. API 密钥保密:
#    - 不要将 .env 提交到 Git
#    - 已在 .gitignore 中配置
#
# 2. 成本控制:
#    - DeepSeek API 按 token 计费
#    - Qwen API 也按 token 计费
#    - 大量测试前建议设置额度告警
#
# 3. 本地模型替代:
#    - 可将 embedding_provider 改为 "local"
#    - 首次会自动下载 HuggingFace 模型
#    - 占用约 4GB 磁盘空间，但无额外 API 成本
#
# 4. 网络要求:
#    - 需要访问以下域名:
#      * api.deepseek.com (LLM)
#      * dashscope.aliyuncs.com (向量/重排)
#      * huggingface.co (本地模型下载)
